{
  "permissions": {
    "allow": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-docs.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "pnpm build --filter $(echo $CLAUDE_FILE | sed 's|packages/\\([^/]*\\)/.*|\\1|') 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
